rules_version = '2';

// All reads and writes go through the FastAPI backend using the Admin SDK,
// which bypasses these rules. Client SDKs therefore get no direct access:
// a modified app cannot read other students' data or forge XP by writing
// to Firestore directly.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
